#include <algorithm>
#include <vector>

// All Catalan numbers that fit in a 32-bit signed ingeter:

const static std::vector<int> CATALAN =
{   1, 1, 2, 5, 14, 42, 132, 429, 1430, 4862, 16796, 58786, 
    208012, 742900, 2674440, 9694845, 35357670, 129644790, 
    477638700, 1767263190 
};

struct Solution 
{
    std::vector<int> countBSTs(const std::vector<int> &arr)
    {
        const int n = int(arr.size());
        std::vector<int> result(n, 0);
        std::vector<int> indices(n, 0);
        for (int i=0; i < n; ++i) indices[i] = i;
        
        std::sort(indices.begin(), indices.end(),
            [arr](int i, int j) { return arr[i] < arr[j]; }
        );

        for (int j = 0; j < n; ++j)
        {
            int i = indices[j];
            result[i] = CATALAN[j] * CATALAN[n - 1 - j];
        }

        return result;
    }
}; 
