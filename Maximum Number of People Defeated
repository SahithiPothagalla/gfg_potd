class Solution {
  public:
    int maxPeopleDefeated(int p) {
        int low = 0, high = 10000, ans = 0;
        
        while (low <= high) {
            int mid = low + (high - low) / 2;
            long long sum = 1LL * mid * (mid + 1) * (2 * mid + 1) / 6;
            
            if (sum <= p) {
                ans = mid;
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        
        return ans;
    }
};
